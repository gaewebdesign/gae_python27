<html>
<head>
</head>

<style type = "text/css"> 
<!--
@import url("/assets/css/courts.css");
-->
</style>
<!--
http://www.fieldofschemes.com/newstyles.css
-->
<body>
<title>Month</title>

<div id=containerlogin>
 {{ LoginForm }} 

</div>



<center>
<h1>{{monthname}} {{year}} </h1>

<div id = "containertop">
<a href= "{{Host}}/delmonth/{{Prev_month}}/{{Prev_year}}" >Previous Month</a> 
&nbsp;&nbsp;&nbsp;&nbsp; 
<a href= "{{Host}}/delmonth/{{Next_month}}/{{Next_year}}" >Next Month</a> 
</div>

<div id = "container">
<br>
<table id="month">
<thead>
<tr>
<th class="weekend" >Monday</th>
<th >Tuesday</th >
<th >Wednesday</th >
<th >Thursday</th > 
<th >Friday</th >
<th class="weekend">Saturday</th >
<th class="weekend" >Sunday</th >
</tr>
</thead >
<tbody>

<!--<form action="Post" action="{{Host}}/dodelmonth"> -->
<form method="Post" action="{{Host}}/dodelmonth">


<input type="submit" value="Delete Court Reservation ">

{% for week in Month %}
   <tr>
   {% for day in week %}
      <td class="{{day.classtype}}"> <a href="{{Host}}/_courts/{{day.month}}/{{day.day}}/{{day.year}}"> {{ day.day }}</a>

      {{ day.holiday }} <br>
<span style="font-family: verdana,sans-serif; font-size:12px;">
      {% for c in day.courts %}

          <input type="checkbox" name="reservation" value="{{c.key}}">
          {{c.time}} 
          {% if c.mine %}
            <b>
          {% endif %}
          {{c.cts}}
          {% if c.mine %}
            </b>
          {% endif %}
          <br>

      {% endfor %}
</span>

   {% endfor %}
   </tr>
{% endfor %}


</form>


</div>


