def MatchTime( d):

   pm = "am"
   hour = d.hour
   minute = ""
   if( d.hour == 12): 
      pm = "pm"    
   elif( d.hour > 12):
      pm = "pm"
      hour = d.hour - 12

   if( d.minute > 0):
      minute= ":"+str(d.minute)            

   return str(hour)+minute+pm



