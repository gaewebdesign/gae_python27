from google.appengine.ext import ndb

class IDList( ndb.Model ):
     id = ndb.StringProperty()
     desc = ndb.StringProperty()


class MatchList( ndb.Model):
     desc = ndb.StringProperty()
     date = ndb.DateTimeProperty()


